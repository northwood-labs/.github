{
  "version": "1.0.0",
  "enabled": true,
  "name": "Clean Markdown files",
  "description": "Runs the fast linters on code changes.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "task lint",
    "timeout": 10
  }
}
