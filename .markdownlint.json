{
  "blanks-around-fences": {
    "list_items": true
  },
  "blanks-around-headings": {
    "lines_above": 1,
    "lines_below": 1
  },
  "blanks-around-lists": true,
  "blanks-around-tables": true,
  "code-block-style": {
    "style": "fenced"
  },
  "code-fence-style": {
    "style": "backtick"
  },
  "commands-show-output": false,
  "descriptive-link-text": {
    "prohibited_texts": [
      "click here",
      "here",
      "link",
      "more"
    ]
  },
  "emphasis-style": {
    "style": "underscore"
  },
  "fenced-code-language": true,
  "first-line-h1": {
    "allow_preamble": true,
    "front_matter_title": "^\\s*(name|title)\\s*[:=]"
  },
  "heading-increment": {
    "front_matter_title": "^\\s*(name|title)\\s*[:=]"
  },
  "heading-start-left": true,
  "heading-style": {
    "style": "atx"
  },
  "hr-style": {
    "style": "consistent"
  },
  "line-length": {
    "code_blocks": false,
    "headings": false,
    "line_length": 100000,
    "stern": false,
    "strict": false,
    "tables": false
  },
  "link-fragments": {
    "ignore_case": false,
    "ignored_pattern": ""
  },
  "link-image-reference-definitions": {
    "ignored_definitions": [
      "//"
    ]
  },
  "link-image-style": {
    "autolink": true,
    "collapsed": true,
    "full": true,
    "inline": true,
    "shortcut": true,
    "url_inline": true
  },
  "list-indent": true,
  "list-marker-space": {
    "ol_multi": 1,
    "ol_single": 1,
    "ul_multi": 1,
    "ul_single": 1
  },
  "no-alt-text": true,
  "no-bare-urls": true,
  "no-blanks-blockquote": true,
  "no-duplicate-heading": {
    "siblings_only": true
  },
  "no-emphasis-as-heading": {
    "punctuation": ".,;:!?"
  },
  "no-empty-links": true,
  "no-hard-tabs": {
    "code_blocks": true,
    "ignore_code_languages": [],
    "spaces_per_tab": 2
  },
  "no-inline-html": {
    "allowed_elements": [
      "a",
      "b",
      "br",
      "code",
      "details",
      "div",
      "img",
      "li",
      "nobr",
      "ol",
      "p",
      "pre",
      "span",
      "summary",
      "ul"
    ],
    "table_allowed_elements": []
  },
  "no-missing-space-atx": true,
  "no-multiple-blanks": {
    "maximum": 1
  },
  "no-multiple-space-atx": true,
  "no-multiple-space-blockquote": {
    "list_items": true
  },
  "no-reversed-links": true,
  "no-space-in-code": true,
  "no-space-in-emphasis": true,
  "no-space-in-links": true,
  "no-trailing-punctuation": {
    "punctuation": ".,;:"
  },
  "no-trailing-spaces": {
    "br_spaces": 2,
    "code_blocks": false,
    "list_item_empty_lines": false,
    "strict": false
  },
  "ol-prefix": {
    "style": "ordered"
  },
  "proper-names": {
    "code_blocks": false,
    "html_elements": false,
    "names": [
      "JSON",
      "macOS",
      "Northwood Labs",
      "OpenTofu",
      "Terraform",
      "Terragrunt",
      "Terratest",
      "TOML",
      "YAML"
    ]
  },
  "reference-links-images": {
    "ignored_labels": [
      "x"
    ],
    "shortcut_syntax": false
  },
  "required-headings": false,
  "single-h1": {
    "front_matter_title": "^\\s*(name|title)\\s*[:=]",
    "level": 1
  },
  "single-trailing-newline": true,
  "strong-style": {
    "style": "asterisk"
  },
  "table-column-count": true,
  "table-column-style": {
    "aligned_delimiter": true,
    "style": "aligned"
  },
  "table-pipe-style": {
    "style": "leading_and_trailing"
  },
  "ul-indent": {
    "indent": 2,
    "start_indent": 4,
    "start_indented": false
  },
  "ul-style": {
    "style": "asterisk"
  }
}
